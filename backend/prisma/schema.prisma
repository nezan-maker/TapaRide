generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String           @id @default(uuid())
  email                 String           @unique
  password              String
  phone                 String           @unique
  role                  Role
  isVerified            Boolean          @default(false)
  agencyIssuedId        String?
  ruraCode              String?
  managedAgencyId       String?
  managedStationId      String?
  driverAgencyId        String?
  refreshToken          String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  lastPasswordChangedAt DateTime         @default(now())
  passwordHistory       String[]
  phoneVerifiedAt       DateTime?
  ownedAgencies         Agency[]         @relation("AgencyOwner")
  idempotencyKeys       IdempotencyKey[]
  organizations         Organization[]   @relation("OrganizationOwner")
  parcels               Parcel[]         @relation("ParcelSender")
  passkeys              Passkey[]
  tickets               Ticket[]
  driverAgency          Agency?          @relation("AgencyDrivers", fields: [driverAgencyId], references: [id])
  managedAgency         Agency?          @relation("AgencyManagers", fields: [managedAgencyId], references: [id])
  managedStation        Station?         @relation("StationManagers", fields: [managedStationId], references: [id])
  vehicle               Vehicle?         @relation("AssignedDriver")
  waitlist              WaitlistEntry[]
  wallet                Wallet?

  @@index([isVerified, phoneVerifiedAt, role])
}

model Passkey {
  id         String   @id
  userId     String
  publicKey  Bytes
  counter    BigInt
  deviceName String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wallet {
  id                   String              @id @default(uuid())
  userId               String              @unique
  walletPassword       String?
  // Available (un-holdable) balance — encrypted at rest with AES-256-GCM.
  encryptedBalance     String?
  // Reserved for in-flight transactions (a parcel send, etc.). Same
  // encryption shape as encryptedBalance. NEVER mutated without a
  // matching WalletTransaction row in the journal.
  encryptedHeldBalance String?
  iv                   String?
  heldBalanceIv        String?
  authTag              String?
  heldBalanceAuthTag   String?
  salt                 String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  // Optimistic-concurrency counter. Every balance/held flip increments.
  version              Int                 @default(0)
  status               WalletStatus        @default(UNINITIALIZED)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions         WalletTransaction[]
}

model WalletTransaction {
  id               String               @id @default(uuid())
  walletId         String
  type             TransactionType
  // Holds vs commits vs releases. Every balance mutation in the ledger
  // begins as PENDING (a hold), then either COMMITs (money moved) or
  // RELEASEs (hold voided). REVERSED is for refund/cancel flows.
  status           TransactionStatus    @default(PENDING)
  // CREDIT adds to balance, DEBIT removes. Redundant with sign of amount but
  // queryable without arithmetic. Required.
  direction        TransactionDirection
  amount           Int // Whole RWF. Sign defined by `direction`.
  // Why this row exists. Free-text shown in dashboard history.
  note             String?
  createdAt        DateTime             @default(now())
  // When status flipped PENDING→COMMITTED.
  committedAt      DateTime?
  // When status flipped PENDING→RELEASED.
  releasedAt       DateTime?
  // When a COMMIT got reversed (refund, dispute resolution).
  reversedAt       DateTime?
  // External id — Stripe payment intent, parcel id, ticket id. Indexed.
  referenceId      String?
  // Set when the row was committed by a Stripe webhook. UNIQUE → same
  // Stripe event delivered twice cannot double-credit.
  stripeEventId    String?            @unique
  idempotencyKeyId String?
  idempotencyKey   IdempotencyKey?    @relation(fields: [idempotencyKeyId], references: [id])
  // Free-form audit detail (e.g. Stripe event payload snapshot, sender
  // IP, journal reconciliation details).
  metadata         Json?
  wallet           Wallet             @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([idempotencyKeyId])
  @@index([walletId, status])
  @@index([referenceId])
  @@index([walletId, createdAt])
}

model Agency {
  id        String    @id @default(uuid())
  name      String
  ownerId   String
  ruraCode  String?
  logoUrl   String?
  verified  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User      @relation("AgencyOwner", fields: [ownerId], references: [id])
  stations  Station[]
  drivers   User[]    @relation("AgencyDrivers")
  managers  User[]    @relation("AgencyManagers")
  vehicles  Vehicle[]

  @@unique([ruraCode])
  @@index([ownerId])
}

model Vehicle {
  id          String    @id @default(uuid())
  plateNumber String    @unique
  model       String
  capacity    Int
  amenities   String[]
  seatLayout  Json?
  agencyId    String
  driverId    String?   @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  journeys    Journey[]
  agency      Agency    @relation(fields: [agencyId], references: [id])
  driver      User?     @relation("AssignedDriver", fields: [driverId], references: [id])
}

model Station {
  id           String        @id @default(uuid())
  name         String
  location     String
  agencyId     String
  createdAt    DateTime      @default(now())
  arrivals     Journey[]     @relation("JourneyDestination")
  departures   Journey[]     @relation("JourneySource")
  journeyStops JourneyStop[]
  agency       Agency        @relation(fields: [agencyId], references: [id])
  managers     User[]        @relation("StationManagers")
}

model Journey {
  id                   String            @id @default(uuid())
  sourceStationId      String
  destinationStationId String
  vehicleId            String
  departureTime        DateTime
  price                Int
  createdAt            DateTime          @default(now())
  bulkBookings         BulkBooking[]
  destinationStation   Station           @relation("JourneyDestination", fields: [destinationStationId], references: [id])
  sourceStation        Station           @relation("JourneySource", fields: [sourceStationId], references: [id])
  vehicle              Vehicle           @relation(fields: [vehicleId], references: [id])
  stops                JourneyStop[]
  parcels              Parcel[]
  tickets              Ticket[]
  positionLogs         TripPositionLog[]
  waitlist             WaitlistEntry[]
}

model TripPositionLog {
  id        String   @id @default(uuid())
  journeyId String
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
  journey   Journey  @relation(fields: [journeyId], references: [id])
}

model Ticket {
  id              String       @id @default(uuid())
  userId          String
  journeyId       String
  seatNumber      Int
  status          TicketStatus @default(PAID)
  createdAt       DateTime     @default(now())
  alightingStopId String?
  boardingStopId  String?
  journey         Journey      @relation(fields: [journeyId], references: [id])
  user            User         @relation(fields: [userId], references: [id])

  @@unique([journeyId, seatNumber], map: "Ticket_paid_seat_per_journey_key", where: raw("(status = 'PAID'::\"TicketStatus\")"))
  @@index([journeyId, seatNumber, status])
}

model Parcel {
  id                 String       @id @default(uuid())
  senderId           String
  receiverName       String
  receiverPhone      String
  journeyId          String
  status             ParcelStatus @default(PENDING)
  // Server-side tracking code — UUID. Used by staff dashboards / DB joins.
  trackingCode       String       @unique @default(uuid())
  // User-typable 12-char claim key shown to sender + SMS'd to receiver.
  // Generated ONLY after payment commits. Plaintext at rest (the key is
  // already shared over SMS, so encrypting only the column is theatre —
  // what matters is replay-resistance: `@@unique` ensures the key is
  // un-gameable as an index).
  claimKey           String?      @unique
  weight             Float?
  fee                Int?
  pricingStrategy    String? // 'LEGACY_WEIGHT_2000' or 'JOURNEY_X_BAND' — for tuning
  basePrice          Int?
  weightBand         String?
  weightMultiplier   Float?
  notes              String?
  // Stripe Payment Intent for the parcel fee (topup-style — sender's
  // wallet is the funding rail; Stripe only sees sender-side charges).
  paymentIntentId    String?      @unique
  paidAt             DateTime?
  claimedAt          DateTime?
  // If the receiver is a Tapa user, this is their User.id. If receiver
  // verifies by claim key only (no account), this stays null and we record
  // hashed phone in claimedByPhoneHash.
  claimedById        String?
  claimedByPhoneHash String?
  // 14-day TTL after paidAt. After EXPIRED the hold is RELEASEd.
  expiresAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  journey            Journey      @relation(fields: [journeyId], references: [id])
  sender             User         @relation("ParcelSender", fields: [senderId], references: [id])

  @@index([status])
  @@index([senderId, status])
  @@index([receiverPhone])
  @@index([expiresAt])
}

model Organization {
  id        String        @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime      @default(now())
  bookings  BulkBooking[]
  owner     User          @relation("OrganizationOwner", fields: [ownerId], references: [id])
}

model BulkBooking {
  id             String          @id @default(uuid())
  organizationId String
  journeyId      String
  destination    String
  departureTime  DateTime
  manifestHash   String
  signature      String
  createdAt      DateTime        @default(now())
  boardingEvents BoardingEvent[]
  journey        Journey         @relation(fields: [journeyId], references: [id])
  organization   Organization    @relation(fields: [organizationId], references: [id])
  passengers     BulkPassenger[]
}

model BulkPassenger {
  id             String          @id @default(uuid())
  bulkBookingId  String
  name           String
  nationalId     String
  seatNumber     Int
  boardingHash   String          @unique
  status         BoardingStatus  @default(PENDING)
  parentPhone    String?
  parentEmail    String?
  boardingEvents BoardingEvent[]
  bulkBooking    BulkBooking     @relation(fields: [bulkBookingId], references: [id])
}

model BoardingEvent {
  id            String         @id @default(uuid())
  passengerId   String?
  bulkBookingId String
  type          String
  location      String?
  timestamp     DateTime       @default(now())
  bulkBooking   BulkBooking    @relation(fields: [bulkBookingId], references: [id])
  passenger     BulkPassenger? @relation(fields: [passengerId], references: [id])
}

model JourneyStop {
  id        String    @id @default(uuid())
  journeyId String
  stationId String
  order     Int
  reachedAt DateTime?
  journey   Journey   @relation(fields: [journeyId], references: [id])
  station   Station   @relation(fields: [stationId], references: [id])
}

model WaitlistEntry {
  id             String   @id @default(uuid())
  userId         String
  journeyId      String
  boardingStopId String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  journey        Journey  @relation(fields: [journeyId], references: [id])
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId, journeyId, boardingStopId, status])
}

model IdempotencyKey {
  id                 String              @id @default(uuid())
  userId             String
  route              String
  key                String
  requestHash        String
  state              IdempotencyState    @default(PROCESSING)
  statusCode         Int?
  responseBody       Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@unique([userId, route, key])
  @@index([createdAt])
  @@index([state, createdAt])
}

enum Role {
  CLIENT
  DRIVER
  MANAGER
  OWNER
  ORGANIZATION
}

enum BoardingStatus {
  PENDING
  BOARDED
  ALIGHTED
}

enum TicketStatus {
  PAID
  COMPLETED
  CANCELLED
}

enum ParcelStatus {
  // Sender-side lifecycle, in order:
  //   PENDING           = parcel registered, fee not yet captured.
  //                      Legacy default kept so prior clients and seeded
  //                      rows still type-check. New code prefers
  //                      AWAITING_PAYMENT to make the lifecycle explicit.
  //   AWAITING_PAYMENT  = sender has the parcel queued, fee NOT yet
  //                      committed in the wallet journal. Sender may
  //                      CANCEL — that releases the wallet hold.
  //   CONFIRMED         = sender's wallet hold committed; claimKey
  //                      minted and SMS-sent to receiver.
  //   IN_TRANSIT / DELIVERED = driven by staff (driver/marker) via PATCH /:id/status.
  //   CLAIMED           = receiver confirmed pickup.
  //   CANCELLED         = sender cancelled before pickup; wallet hold RELEASEd.
  //   EXPIRED           = 14d elapsed with no claim; wallet hold RELEASEd.
  PENDING
  AWAITING_PAYMENT
  CONFIRMED
  IN_TRANSIT
  DELIVERED
  CLAIMED
  CANCELLED
  EXPIRED
}

enum TransactionType {
  // Legacy values — kept for backwards compatibility with the existing
  // wallet service. New code should use the *_PARCEL_* / *_TICKET_*
  // variants below for granular audit history.
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  // Granular values introduced for the parcel receive-flow and to give
  // tickets their proper journal entry. Idempotent and pure: they map to
  // (direction, status) pairs in WalletTransaction.
  TOPUP // CREDIT/COMMITTED — Stripe-funded wallet credit
  TICKET_PURCHASE // DEBIT/PENDING   → DEBIT/COMMITTED on success
  TICKET_REFUND // CREDIT/REVERSED (against a prior purchase)
  PARCEL_SEND // DEBIT/PENDING   → DEBIT/COMMITTED on payment
  PARCEL_SEND_REFUND // CREDIT/REVERSED
  ADJUSTMENT // Manual operator reconciliation row
}

/**
 * State machine for a single WalletTransaction row.
 * PENDING   = hold placed; not yet COMMITTED (e.g. awaiting Stripe webhook).
 * COMMITTED = money permanently moved between balance and heldBalance.
 * RELEASED  = a hold was voided without commit (e.g. Stripe charge failed).
 * REVERSED  = a prior COMMIT was undone (refund, dispute).
 * Terminal states: COMMITTED, RELEASED, REVERSED.
 */
enum TransactionStatus {
  PENDING
  COMMITTED
  RELEASED
  REVERSED
}

/**
 * CREDIT adds to balance. DEBIT removes from balance (typically accompanied
 * by an increment of heldBalance while PENDING, then a decrement of
 * heldBalance on commit / release).
 */
enum TransactionDirection {
  CREDIT
  DEBIT
}

enum IdempotencyState {
  PROCESSING
  COMPLETED
  FAILED
}

enum WalletStatus {
  UNINITIALIZED
  ACTIVE
}
