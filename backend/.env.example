# Copy to backend/.env and fill in secrets.
# Generate secure values: pnpm env:generate

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Local PostgreSQL (development on your machine) ───────────────────────────
# Replace YOUR_PASSWORD with your local Postgres password.
DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/tapa_ride

# ── Neon PostgreSQL (production / Render deployment) ─────────────────────────
# Uncomment and use these instead of the local URL above when deploying.
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#
# Notes:
#   - DATABASE_URL → pooled connection (app runtime)
#   - DIRECT_URL   → direct connection (Prisma migrations; optional locally)
#   - The app auto-selects the Neon driver when the host contains "neon.tech"

# Redis — start with: docker compose up -d redis
REDIS_URL=redis://localhost:6379

JWT_SECRET=REPLACE_WITH_64_CHAR_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_SECRET
DATABASE_ENCRYPTION_KEY=REPLACE_WITH_64_HEX_CHARS
HMAC_SECRET=REPLACE_WITH_64_CHAR_SECRET
METRICS_TOKEN=REPLACE_WITH_64_CHAR_SECRET

WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173
EMAIL_VERIFICATION_ORIGIN=http://localhost:5173

EMAIL_PROVIDER=console
SMS_PROVIDER=console
MAIL_FROM=no-reply@tapa.local

# Google Sign-In (OAuth 2.0 Web client)
GOOGLE_CLIENT_ID=

# Production only — comma-separated browser origins
# CORS_ORIGIN=https://taparide.onrender.com
